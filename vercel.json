{
  "version": 2,
  "builds": [
    {
      "src": "deeptrace-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "deeptrace-frontend/dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python@4.2.3"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "deeptrace-frontend/dist/$1"
    }
  ]
}
