{
  "version": 2,
  "installCommand": "cd deeptrace-frontend && npm install && pip install -r ../deeptrace_backend/requirements.txt",
  "buildCommand": "cd deeptrace-frontend && npm run build",
  "outputDirectory": "deeptrace-frontend/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)\\..*", "dest": "/$1.$2" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
