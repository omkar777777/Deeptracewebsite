{
  "version": 2,
  "installCommand": "cd deeptrace-frontend && npm install",
  "buildCommand": "cd deeptrace-frontend && npm run build",
  "outputDirectory": "deeptrace-frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
